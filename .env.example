# Resend API Key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# 送信元
# - テスト: Apo Check <onboarding@resend.dev>（通知は RESEND_SANDBOX_RECIPIENT のみ届く）
# - 本番: 検証済みドメインのアドレス（例: Apo Check <notify@your-domain.com>）
RESEND_FROM=Apo Check <onboarding@resend.dev>

# テスト送信時のみ使用（onboarding@resend.dev 利用時はこの1件にしか送れない）
RESEND_SANDBOX_RECIPIENT=daisuke.araseki@gmail.com

# 通知先メールアドレス（カンマ区切りで複数指定可）
# ※ 検証済みドメインの RESEND_FROM を設定した後に複数宛先へ配信可能
NOTIFICATION_EMAIL=daisuke.araseki@gmail.com

# Google Apps Script（予約台帳）
# gas/apo-sheet-api.gs をスプレッドシートの Apps Script に貼り付けてウェブアプリとしてデプロイ
GAS_WEB_APP_URL=https://script.google.com/macros/s/xxxxxxxx/exec
GAS_API_SECRET=setupApiSecret で生成した値
